{
  "extends": "@baota/typescript/vue.json",
  "compilerOptions": {
    "jsx": "preserve",
    "paths": {
      "@/*": ["./src/*"],
      "@views/*": ["./src/views/*"],
      "@styles/*": ["./src/styles/*"],
      "@stores/*": ["./src/stores/*"],
      "@components/*": ["./src/components/*"],
      "@api/*": ["./src/api/*"],
      "@types/*": ["./src/types/*"],
      "@assets/*": ["./src/assets/*"],
      "@locales/*": ["./src/locales/*"],
      "@router/*": ["./src/router/*"],
      "@layout/*": ["./src/views/layout/*"]
    },
    "plugins": [{ "name": "typescript-plugin-css-modules" }],
    "types": ["vite/client"]
  },
  "include": [
    "types/*.d.ts",
    "src/*.tsx",
    "src/*.ts",
    "src/components/**/*.ts",
    "src/components/**/*.tsx",
    "src/**/*.tsx",
    "src/**/*.vue",
    "src/**/*.js",
    "src/**/*.jsx",
    "src/**/*.d.ts"
  ]
}
