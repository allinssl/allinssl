{
	"name": "domain-management-backend",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"build:no-check": "vite build",
		"preview": "vite preview",
		"check": "vue-tsc -b",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"stylelint": "stylelint \"src/**/*.{css,scss,vue}\"",
		"stylelint:fix": "stylelint \"src/**/*.{css,scss,vue}\" --fix",
		"format": "prettier --write \"**/*.{js,jsx,ts,tsx,vue,html,css,scss,less,json,md,yaml,yml}\"",
		"format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,vue,html,css,scss,less,json,md,yaml,yml}\"",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest --coverage",
		"gulp": "gulp",
		"gulp:build": "gulp prebuild",
		"gulp:lint": "gulp lint",
		"gulp:assets": "gulp assets",
		"precommit": "gulp precommit"
	},
	"dependencies": {
		"@baota/i18n": "workspace:*",
		"@baota/naive-ui": "workspace:*",
		"@baota/hooks": "workspace:*",
		"@baota/utils": "workspace:*",
		"@vicons/antd": "^0.13.0",
		"axios": "^1.11.0",
		"clsx": "^2.1.1",
		"lucide-vue-next": "^0.511.0",
		"naive-ui": "^2.42.0",
		"pinia": "^3.0.3",
		"pinia-plugin-persistedstate": "^4.5.0",
		"@vicons/ionicons5": "^0.13.0",
		"vue": "^3.5.18",
		"vue-i18n": "^11.1.2",
		"vue-router": "^4.5.1",
		"vue-sonner": "^1.3.2"
	},
	"devDependencies": {
		"@baota/eslint": "workspace:*",
		"@baota/typescript": "workspace:*",
		"@baota/prettier": "workspace:*",
		"@baota/vite-plugin-path-random": "workspace:*",
		"@iconify-json/carbon": "^1.2.11",
		"@types/node": "^22.17.0",
		"@unocss/vite": "^66.3.3",
		"@vicons/material": "^0.13.0",
		"@vitejs/plugin-vue": "^6.0.1",
		"@vitejs/plugin-vue-jsx": "^5.0.1",
		"@vue/runtime-dom": "^3.5.18",
