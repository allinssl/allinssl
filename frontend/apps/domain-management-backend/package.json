		"globals": "^13.24.0",
		"jsdom": "^26.1.0",
		"prettier": "^3.6.2",
		"prettier-eslint": "^16.4.2",
		"sass": "^1.89.2",
		"typescript": "~5.3.3",
		"typescript-plugin-css-modules": "^5.1.0",
		"unocss": "^66.3.3",
		"unplugin-auto-import": "^19.3.0",
		"unplugin-vue-components": "^28.8.0",
		"unplugin-vue-dev-locator": "^1.0.3",
		"vite": "^7.0.6",
		"vite-plugin-svg-icons": "^2.0.1",
		"vitest": "^3.2.4",
		"vue-tsc": "^1.8.27"
